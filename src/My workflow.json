        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"response\": {\n      \"type\": \"string\",\n      \"description\": \"The main response to the user\"\n    },\n    \"needs_more_info\": {\n      \"type\": \"boolean\",\n      \"description\": \"Whether more information is needed\"\n    },\n    \"follow_up_questions\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"description\": \"Questions to ask if more info needed\"\n    },\n    \"foods_to_avoid\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"description\": \"Foods to avoid for disease_food requests\"\n    },\n    \"foods_to_include\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"description\": \"Foods to include for disease_food requests\"\n    },\n    \"diet_plan\": {\n      \"type\": \"object\",\n      \"description\": \"Structured diet plan for diet_plan requests\"\n    },\n    \"disclaimer\": {\n      \"type\": \"string\",\n      \"description\": \"Mandatory health disclaimer\"\n    }\n  },\n  \"required\": [\"response\", \"needs_more_info\", \"disclaimer\"]\n}"
      },

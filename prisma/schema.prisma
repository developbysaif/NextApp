// IlajBilGhiza - Complete Health & Wellness Platform
// Database Schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  DOCTOR
  USER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum Goal {
  WEIGHT_LOSS
  SLIGHT_LOSS
  MAINTENANCE
  MUSCLE_GAIN
  HEAVY_GAIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum MealCategory {
  BREAKFAST
  LUNCH
  SNACK
  DINNER
  SEHRI
  IFTAR
}

enum LogStatus {
  COMPLETED
  IN_PROGRESS
  SKIPPED
  NOT_STARTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          UserRole  @default(USER)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile & Health Data
  profile       Profile?
  
  // Relations
  doctorProfile Doctor?
  dietPlans     DietPlan[]
  foodLogs      FoodLog[]
  exerciseLogs  ExerciseLog[]
  measurements  BodyMeasurement[]
  progressPhotos ProgressPhoto[]
  weightLogs    WeightLog[]
  groceryLists  GroceryList[]
  appointments  Appointment[] @relation("UserAppointments")
  orders        Order[]
  reviews       Review[]
  comments      Comment[]
  
  // Messaging
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  conversations    ConversationParticipant[]

  @@map("users")
}

model Profile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  age           Int?
  gender        Gender?
  weight        Float?        // in kg
  height        Float?        // in cm
  activityLevel ActivityLevel?
  goal          Goal?
  
  // Medical
  diseases      String[]      // Array of disease names/IDs
  symptoms      String[]
  preferences   String[]      // e.g. ["halal", "dairy_free"]
  
  // Goals
  targetWeight  Float?
  dailyCalorieGoal Int?
  waterGoal     Float?        @default(2.0) // in Liters
  stepGoal      Int?          @default(8000)
  sleepGoal     Float?        @default(8.0) // in hours
  
  @@map("profiles")
}

model Doctor {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specialization    String
  qualification     String
  experienceYears   Int
  pmdcNumber        String          @unique
  availableSlots    Json?           // Storing availability
  consultationFee   Float
  rating            Float           @default(0.0)
  reviewCount       Int             @default(0)
  verificationStatus ApprovalStatus @default(PENDING)
  
  bio               String?         @db.Text
  clinicName        String?
  clinicAddress     String?
  
  // Relations
  appointments      Appointment[]
  articles          Article[]
  
  @@map("doctors")
}

model DietPlan {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String
  dailyCalories   Int
  protein         Int       // in grams
  carbs           Int
  fat             Int
  fiber           Int?
  
  bmi             Float?
  bmiCategory     String?
  
  // Structured Menu
  weekPlan        Json      // Detailed 7-day plan
  
  organicFoods    String[]
  sunnahFoods     String[]
  herbalDrinks    Json?
  healthNotes     String?   @db.Text
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  
  @@map("diet_plans")
}

model FoodLog {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date          DateTime      @default(now())
  time          String?       // "07:30 AM"
  category      MealCategory
  foodName      String
  amount        String?       // "1 cup", "100g"
  calories      Int
  protein       Int?
  carbs         Int?
  fat           Int?
  
  @@map("food_logs")
}

model Exercise {
  id            String    @id @default(cuid())
  name          String
  description   String?   @db.Text
  category      String?   // "strength", "cardio", "yoga"
  metValue      Float?    // Metabolic Equivalent of Task for calorie calc
  
  @@map("exercises")
}

model ExerciseLog {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exerciseName  String
  date          DateTime      @default(now())
  sets          Int?
  reps          String?       // Can be "12 reps" or "60 sec"
  rest          String?       // "60 sec"
  weight        String?       // "45 kg" or "Bodyweight"
  caloriesBurned Int?
  status        LogStatus     @default(NOT_STARTED)
  
  @@map("exercise_logs")
}

model BodyMeasurement {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date          DateTime  @default(now())
  chest         Float?
  waist         Float?
  arm           Float?
  hips          Float?
  thigh         Float?
  neck          Float?
  
  @@map("body_measurements")
}

model WeightLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  weight        Float
  date          DateTime  @default(now())
  
  @@map("weight_logs")
}

model ProgressPhoto {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  imageUrl      String
  date          DateTime  @default(now())
  label         String?   // e.g. "Front View", "Side View"
  
  @@map("progress_photos")
}

model GroceryList {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name          String    @default("My Grocery List")
  totalCost     Float     @default(0.0)
  totalCalories Int       @default(0)
  createdAt     DateTime  @default(now())
  
  items         GroceryItem[]
  
  @@map("grocery_lists")
}

model GroceryItem {
  id            String        @id @default(cuid())
  listId        String
  list          GroceryList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  
  name          String
  category      String
  quantity      String
  calories      Int?
  cost          Float?
  isPurchased   Boolean       @default(false)
  
  @@map("grocery_items")
}

model Product {
  id            String    @id @default(cuid())
  nameEn        String
  nameUr        String?
  description   String    @db.Text
  price         Float
  category      String
  stock         Int       @default(0)
  imageUrl      String?
  isSunnah      Boolean   @default(false)
  benefits      String?   @db.Text
  rating        Float     @default(0.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("products")
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  totalAmount   Float
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?       // "Stripe", "JazzCash", "EasyPaisa"
  
  shippingAddress String?
  contactNumber   String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  items         OrderItem[]
  
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId     String
  name          String
  quantity      Int
  price         Float
  image         String?
  
  @@map("order_items")
}

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation("UserAppointments", fields: [userId], references: [id], onDelete: Cascade)
  
  doctorId      String
  doctor        Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  dateTime      DateTime
  status        AppointmentStatus @default(PENDING)
  notes         String?           @db.Text
  consultationLink String?
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  @@map("appointments")
}

model Article {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  content       String      @db.Text
  excerpt       String?     @db.Text
  image         String?
  
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  category      String
  tags          String[]
  status        BlogStatus  @default(DRAFT)
  views         Int         @default(0)
  isFeatured    Boolean     @default(false)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  comments      Comment[]
  
  @@map("articles")
}

model Disease {
  id            String    @id @default(cuid())
  nameEn        String
  nameUr        String?
  description   String?   @db.Text
  symptoms      String[]
  causes        String[]
  foodsToEat    String[]
  foodsToAvoid  String[]
  remedies      String?   @db.Text
  specialist    String?
  sunnahRefs    String[]
  
  createdAt     DateTime  @default(now())
  
  @@map("diseases")
}

model Comment {
  id            String    @id @default(cuid())
  content       String    @db.Text
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  articleId     String?
  article       Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  
  @@map("comments")
}

model Review {
  id            String    @id @default(cuid())
  rating        Int
  comment       String?   @db.Text
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId     String?
  // Could link to Doctor or Product
  
  createdAt     DateTime  @default(now())
  
  @@map("reviews")
}

// Messaging Models

model Conversation {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  participants  ConversationParticipant[]
  messages      Message[]
  
  @@map("conversations")
}

model ConversationParticipant {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId        String
  sender          User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId      String?
  receiver        User?          @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  content         String        @db.Text
  type            String        @default("TEXT") // TEXT, IMAGE, FILE
  fileUrl         String?
  fileName        String?
  readAt          DateTime?
  
  createdAt       DateTime      @default(now())
  
  @@map("messages")
}

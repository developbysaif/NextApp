// Doctor Blog & Medical Information Platform
// Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum FoodType {
  VEGETABLE
  FRUIT
  FOOD
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(PATIENT)
  fullName      String    @map("full_name") @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLogin     DateTime? @map("last_login")

  // Relations
  doctor              Doctor?
  sessions            Session[]
  createdCategories   Category[]        @relation("CategoryCreator")
  approvedDoctors     Doctor[]          @relation("DoctorApprover")
  approvedBlogs       Blog[]            @relation("BlogApprover")
  approvedReviews     Review[]          @relation("ReviewApprover")
  ratings             Rating[]
  reviews             Review[]          @relation("UserReviews")
  blogComments        BlogComment[]
  createdFoodItems    FoodItem[]        @relation("FoodItemCreator")
  orders              Order[]           @relation("UserOrders")

  @@map("users")
}

model Doctor {
  id                  String          @id @default(uuid())
  userId              String          @unique @map("user_id")
  qualification       String          @db.VarChar(500)
  specialization      String          @db.VarChar(255)
  registrationNumber  String          @unique @map("registration_number") @db.VarChar(100)
  experienceYears     Int             @map("experience_years")
  profilePicture      String?         @map("profile_picture") @db.VarChar(500)
  clinicLogo          String?         @map("clinic_logo") @db.VarChar(500)
  clinicName          String?         @map("clinic_name") @db.VarChar(255)
  clinicAddress       String?         @map("clinic_address") @db.Text
  bio                 String?         @db.Text
  consultationFee     Decimal?        @map("consultation_fee") @db.Decimal(10, 2)
  approvalStatus      ApprovalStatus  @default(PENDING) @map("approval_status")
  approvedById        String?         @map("approved_by")
  approvedAt          DateTime?       @map("approved_at")
  rejectionReason     String?         @map("rejection_reason") @db.Text
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  // Relations
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy          User?           @relation("DoctorApprover", fields: [approvedById], references: [id])
  blogs               Blog[]
  ratings             Rating[]
  reviews             Review[]
  verifiedFoodItems   FoodItem[]      @relation("FoodItemVerifier")

  digitalSignature    String?         @map("digital_signature") @db.VarChar(500)
  medicalLicense      String?         @map("medical_license") @db.VarChar(500)

  @@index([userId])
  @@index([approvalStatus])
  @@index([specialization])
  @@map("doctors")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  icon        String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  createdBy     User          @relation("CategoryCreator", fields: [createdById], references: [id])
  blogs         Blog[]
  foodBenefits  FoodBenefit[]

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

model Blog {
  id              String          @id @default(uuid())
  doctorId        String          @map("doctor_id")
  title           String          @db.VarChar(500)
  slug            String          @unique @db.VarChar(500)
  content         String          @db.LongText
  excerpt         String?         @db.Text
  featuredImage   String?         @map("featured_image") @db.VarChar(500)
  categoryId      String          @map("category_id")
  tags            Json?
  status          BlogStatus      @default(DRAFT)
  approvalStatus  ApprovalStatus  @default(PENDING) @map("approval_status")
  approvedById    String?         @map("approved_by")
  approvedAt      DateTime?       @map("approved_at")
  rejectionReason String?         @map("rejection_reason") @db.Text
  viewsCount      Int             @default(0) @map("views_count")
  isFeatured      Boolean         @default(false) @map("is_featured")
  publishedAt     DateTime?       @map("published_at")
  metaTitle       String?         @map("meta_title") @db.VarChar(255)
  metaDescription String?         @map("meta_description") @db.VarChar(500)
  hasDisclaimer   Boolean         @default(true) @map("has_disclaimer")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id])
  approvedBy    User?         @relation("BlogApprover", fields: [approvedById], references: [id])
  comments      BlogComment[]

  @@index([doctorId])
  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([approvalStatus])
  @@index([publishedAt])
  @@map("blogs")
}

model Rating {
  id        String   @id @default(uuid())
  doctorId  String   @map("doctor_id")
  userId    String   @map("user_id")
  rating    Int      @db.TinyInt // 1-5
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([doctorId, userId])
  @@index([doctorId])
  @@index([userId])
  @@map("ratings")
}

model Review {
  id           String    @id @default(uuid())
  doctorId     String    @map("doctor_id")
  userId       String    @map("user_id")
  reviewText   String    @map("review_text") @db.Text
  isApproved   Boolean   @default(false) @map("is_approved")
  approvedById String?   @map("approved_by")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  doctor     Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user       User   @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User?  @relation("ReviewApprover", fields: [approvedById], references: [id])

  @@index([doctorId])
  @@index([userId])
  @@index([isApproved])
  @@map("reviews")
}

model FoodItem {
  id                String    @id @default(uuid())
  name              String    @db.VarChar(255)
  slug              String    @unique @db.VarChar(255)
  type              FoodType
  image             String?   @db.VarChar(500)
  description       String?   @db.Text
  nutritionalInfo   Json?     @map("nutritional_info")
  createdById       String    @map("created_by")
  verifiedByDoctorId String?  @map("verified_by_doctor")
  isVerified        Boolean   @default(false) @map("is_verified")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  createdBy        User          @relation("FoodItemCreator", fields: [createdById], references: [id])
  verifiedByDoctor Doctor?       @relation("FoodItemVerifier", fields: [verifiedByDoctorId], references: [id])
  benefits         FoodBenefit[]

  @@index([slug])
  @@index([type])
  @@index([isVerified])
  @@map("food_items")
}

model FoodBenefit {
  id                  String   @id @default(uuid())
  foodItemId          String   @map("food_item_id")
  diseaseCategoryId   String   @map("disease_category_id")
  benefits            String   @db.Text
  recommendedQuantity String?  @map("recommended_quantity") @db.VarChar(255)
  warnings            String?  @db.Text
  preparationTips     String?  @map("preparation_tips") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  foodItem        FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  diseaseCategory Category @relation(fields: [diseaseCategoryId], references: [id])

  @@index([foodItemId])
  @@index([diseaseCategoryId])
  @@map("food_benefits")
}

model BlogComment {
  id              String    @id @default(uuid())
  blogId          String    @map("blog_id")
  userId          String    @map("user_id")
  parentCommentId String?   @map("parent_comment_id")
  commentText     String    @map("comment_text") @db.Text
  isApproved      Boolean   @default(false) @map("is_approved")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  blog          Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment BlogComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies       BlogComment[] @relation("CommentReplies")

  @@index([blogId])
  @@index([userId])
  @@index([parentCommentId])
  @@index([isApproved])
  @@map("blog_comments")
}

model Order {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  address     String?     @db.Text
  phone       String?     @db.VarChar(20)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  user        User        @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  name      String   @db.VarChar(255)
  image     String?  @db.VarChar(500)
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}
